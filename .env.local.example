# Copy this file to .env.local and fill in your values

# Sanity — from sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token (for migration script only — not needed for the app itself)
# SANITY_WRITE_TOKEN=your_write_token_here

# Revalidation secret — used by Sanity webhook to trigger ISR
# Set the same value in Sanity → your project → API → Webhooks
REVALIDATE_SECRET=your_random_secret_here

# ── Draft-mode preview (optional) ─────────────────────────────────────────────
# Read token to fetch unpublished drafts (create at sanity.io/manage → API → Tokens, Viewer/read scope)
SANITY_API_READ_TOKEN=
# Shared secret gating the /api/preview route (any random string; used by the Studio Preview button)
NEXT_PUBLIC_SANITY_PREVIEW_SECRET=
